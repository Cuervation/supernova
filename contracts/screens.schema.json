{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://supernova.local/contracts/screens.schema.json",
  "title": "Supernova Screens Contract",
  "type": "object",
  "required": ["screens"],
  "properties": {
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "route", "title", "status", "requiresAuth", "purpose"],
        "properties": {
          "id": {
            "type": "string",
            "enum": ["home", "login", "game", "result", "ranking", "instructions", "settings", "credits", "rewards"]
          },
          "route": { "type": "string", "pattern": "^/" },
          "title": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["mvp", "planned"] },
          "requiresAuth": { "type": "boolean" },
          "purpose": { "type": "string", "minLength": 1 },
          "primaryAction": { "type": "string" },
          "usesServices": {
            "type": "array",
            "items": { "type": "string", "enum": ["AuthService", "RankingService", "GameState", "TimerService"] }
          },
          "animations": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
