{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://supernova.local/contracts/auth.schema.json",
  "title": "Supernova Auth Contract",
  "type": "object",
  "required": ["authUser", "authPort"],
  "properties": {
    "authUser": {
      "type": "object",
      "required": ["uid", "displayName", "email"],
      "properties": {
        "uid": { "type": "string", "minLength": 1 },
        "displayName": { "type": ["string", "null"] },
        "email": { "type": ["string", "null"], "format": "email" },
        "provider": { "type": "string", "minLength": 1 },
        "photoURL": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "authPort": {
      "type": "object",
      "required": ["methods"],
      "properties": {
        "methods": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["getCurrentUser", "signIn", "signOut", "onAuthStateChanged"]
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
