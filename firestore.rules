rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isStringOrNull(value) {
      return value == null || value is string;
    }

    function hasValidGameResultShape() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'displayName',
        'email',
        'durationMs',
        'durationSeconds',
        'completedPairs',
        'totalPairs',
        'completed',
        'createdAt',
        'gameVersion',
        'provider'
      ])
      && request.resource.data.keys().hasAll([
        'uid',
        'displayName',
        'email',
        'durationMs',
        'durationSeconds',
        'completedPairs',
        'totalPairs',
        'completed',
        'createdAt',
        'gameVersion',
        'provider'
      ]);
    }

    function isValidGameResultCreate() {
      return hasValidGameResultShape()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.uid is string
        && isStringOrNull(request.resource.data.displayName)
        && isStringOrNull(request.resource.data.email)
        && request.resource.data.durationMs is number
        && request.resource.data.durationMs > 0
        && request.resource.data.durationSeconds is number
        && request.resource.data.durationSeconds > 0
        && request.resource.data.completed == true
        && request.resource.data.completedPairs is int
        && request.resource.data.totalPairs is int
        && request.resource.data.completedPairs == request.resource.data.totalPairs
        && request.resource.data.totalPairs == 5
        && request.resource.data.createdAt == request.time
        && request.resource.data.gameVersion is string
        && request.resource.data.gameVersion.size() > 0
        && request.resource.data.provider is string
        && request.resource.data.provider.size() > 0;
    }

    match /users/{uid} {
      allow read, create, update: if isOwner(uid);
      allow delete: if false;
    }

    match /gameResults/{resultId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidGameResultCreate();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
