# Providers: firebase | mock
VITE_AUTH_PROVIDER=firebase

# Ranking providers: api | firebase | mock
VITE_RANKING_PROVIDER=api

# Game session providers: api | mock
VITE_GAME_SESSION_PROVIDER=api

# Backend API URL
VITE_API_BASE_URL=http://localhost:3001

# Firebase Web App config. These values are public frontend config, not server secrets.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
